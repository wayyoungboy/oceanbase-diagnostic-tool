# obdiag agent Configuration
#
# File layout:
#   ~/.obdiag/
#     config.yml        — cluster connection config (SSH nodes, DB host/port)
#     config/
#       agent.yml       — all agent config: LLM, skills, MCP, UI  (this file)
#                         also stores TUI runtime state (theme, warnings) — auto-managed sections
#       sessions.db     — conversation history (SQLite, auto-managed)
#       history.jsonl   — chat input history (auto-managed)
#
# Setup: mkdir -p ~/.obdiag/config && cp conf/agent.yml.example ~/.obdiag/config/agent.yml

# ---------------------------------------------------------------------------
# LLM — OpenAI-compatible gateway
# ---------------------------------------------------------------------------

llm:
  base_url: "https://api.openai.com/v1"   # custom gateway URL, or leave blank for openai.com
  api_key: ""                              # injected as OPENAI_API_KEY at startup
  model: "gpt-4o"                         # model name passed to the gateway
  # headers:                              # optional extra HTTP headers for the gateway
  #   X-Custom-Auth: "token123"

# ---------------------------------------------------------------------------
# obdiag-specific settings
# ---------------------------------------------------------------------------

skills:
  enabled: true
  directory: ""          # default: ~/.obdiag/agent/skills/
  validate: true
  script_timeout: 60
  run_script_tool: false

# OceanBase knowledge gateway (optional, off by default)
oceanbase_knowledge:
  enabled: false
  bearer_token: ""

mcp:
  enabled: true

ui:
  tool_approval: true    # require confirmation before executing tools
  show_tool_trace: true  # print each tool call during a turn
  auto_compact: true     # auto-compact conversation when context is nearly full

# ---------------------------------------------------------------------------
# The sections below are auto-managed by the TUI. Do not edit manually.
# ---------------------------------------------------------------------------
# models:       — last-used / default model (set via /model command)
# warnings:     — suppressed warning dialogs
# ui.theme:     — UI theme preference
# mcp_trust:    — approved MCP server fingerprints
